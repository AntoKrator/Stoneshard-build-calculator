{
  "name": "stoneshard-build-calculator",
  "description": "A complete build calculator for Stoneshard: skills, attributes, derived stats, equipment, enchantments, DPS and build comparison.",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && cp dist/index.html dist/404.html",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate-data": "tsx scripts/validate-data.ts",
    "bootstrap": "tsx scripts/bootstrap-from-nstratos.ts",
    "vendor:wiki": "tsx tools/wiki-extractor/fetch.ts",
    "vendor:enemies": "tsx tools/wiki-extractor/fetch-enemies.ts",
    "vendor:item-icons": "tsx tools/wiki-extractor/fetch-icons.ts",
    "vendor:enemy-icons": "tsx tools/wiki-extractor/fetch-enemy-icons.ts",
    "vendor:character-icons": "tsx tools/wiki-extractor/fetch-character-icons.ts",
    "apply-wiki-positions": "tsx scripts/apply-wiki-positions.ts",
    "transform-items": "tsx scripts/transform-items.ts",
    "transform-enemies": "tsx scripts/transform-enemies.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^26.1.0",
    "eslint": "^10.7.0",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
